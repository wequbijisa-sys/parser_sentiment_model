# Runtime
ENVIRONMENT=local
LOG_LEVEL=INFO

# MinIO / S3-compatible storage
MINIO_ENDPOINT_URL=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=raw-text-items
MINIO_REGION=us-east-1
MINIO_SECURE=false

# Model API endpoint
MODEL_API_URL=http://localhost:8080/predict
MODEL_API_AUTH_TOKEN=
MODEL_API_AUTH_HEADER=Authorization
MODEL_API_TIMEOUT_SECONDS=10
MODEL_API_MAX_RETRIES=3

# Rate limiting
GLOBAL_REQUESTS_PER_MINUTE=60
# Optional comma-separated source limits, e.g. reddit:30,rss:120,reviews:20
PER_SOURCE_REQUESTS_PER_MINUTE=
# Optional token bucket capacity. Defaults to each limiter RPM.
BURST_SIZE=

# Flow settings
POLLING_INTERVAL_SECONDS=60
BATCH_MAX_ITEMS=100

# Reddit official API / PRAW settings
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=streaming-text-ingestion/0.1 by your-company
REDDIT_SUBREDDITS=MachineLearning,python
REDDIT_LIMIT=25

# RSS / news feeds. Comma separated public feed URLs.
RSS_FEED_URLS=https://hnrss.org/frontpage
RSS_LIMIT=50

# Generic public reviews API adapter
REVIEWS_API_URL=
REVIEWS_API_TOKEN=
REVIEWS_LIMIT=50
